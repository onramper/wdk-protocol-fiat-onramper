{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    // DOM gives us the WebCrypto (`crypto.subtle`), `fetch`, `TextEncoder` and
    // IndexedDB typings that the web and Node adapters share. We deliberately do
    // NOT add `"node"` to `types`: keeping Node globals out of scope stops us
    // accidentally reaching for `Buffer`/`process` and breaking the browser/RN
    // builds. The Node adapter only differs in storage/fingerprint, not crypto.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
