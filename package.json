{
  "name": "@onramper/wdk-protocol-fiat-onramper",
  "version": "0.2.0",
  "description": "Onramper fiat on/off-ramp protocol for the Tether WDK — extends @tetherto/wdk-wallet FiatProtocol (web, Node, Bare)",
  "license": "Apache-2.0",
  "author": "Onramper <engineering@onramper.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onramper/wdk-protocol-fiat-onramper.git"
  },
  "homepage": "https://github.com/onramper/wdk-protocol-fiat-onramper#readme",
  "bugs": "https://github.com/onramper/wdk-protocol-fiat-onramper/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "bare": {
        "types": "./dist/index.d.ts",
        "default": "./bare.js"
      },
      "browser": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.browser.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.browser.cjs"
        }
      },
      "node": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.node.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.node.cjs"
        }
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "bare.js",
    "assets"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "format": "biome format . --write",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "validate": "npm run check && npm run typecheck && npm run test && npm run build && npm run validate:exports",
    "validate:exports": "attw --pack . --ignore-rules no-resolution && publint",
    "prepublishOnly": "npm run validate"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@tetherto/wdk-wallet": "^1.0.0-beta.15",
    "bare-node-runtime": "^1.5.0",
    "bignumber.js": "^9.3.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "publint": "^0.3.18",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "sideEffects": false
}
